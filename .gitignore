# =============================================================================
# ledger-fortress .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Node/TypeScript
# ---------------------------------------------------------------------------
node_modules/
dist/
build/
out/
.next/
*.tsbuildinfo
.tsbuildinfo
.npm/
.pnp.*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.parcel-cache/
.vite/

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.eggs/
.Python
.python-version
pip-wheel-metadata/
pip-log.txt
pip-delete-this-directory.txt
.venv/
venv/
env/
ENV/
.pyenv/
.pdm-build/
__pypackages__/

# ---------------------------------------------------------------------------
# Testing & coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyright/
.tox/
.nox/
.cache/
coverage/
.coverage
.coverage.*
htmlcov/
nosetests.xml
coverage.xml
*.cover
junit.xml

# ---------------------------------------------------------------------------
# Env/secrets (NEVER commit)
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample
!.env.template
.sentryclirc
.sentryclirc.*
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
.secrets/
*.local

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------------------------------------------------------------
# Editor/IDE
# ---------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
.idea/
*.iml
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------------------------------------------------------------------------
# Local dev/docker volumes
# ---------------------------------------------------------------------------
examples/docker-compose-local/volumes/
docker-compose.override.yml
*.sqlite
*.sqlite3
*.db
node_modules/
dist/
*.egg-info/
__pycache__/
.env
.env.*
!.env.example
*.pyc
.pytest_cache/
.ruff_cache/
coverage/
.DS_Store
