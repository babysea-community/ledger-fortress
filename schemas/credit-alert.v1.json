{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ledger-fortress.dev/schemas/credit-alert.v1.json",
  "title": "CreditAlert",
  "description": "Emitted when a credit balance crosses a configured threshold. Delivered via in-app notification, email, or webhook.",
  "type": "object",
  "required": [
    "schema_version",
    "event_id",
    "account_id",
    "threshold",
    "balance",
    "occurred_at"
  ],
  "properties": {
    "schema_version": {
      "const": "credit-alert.v1",
      "description": "Always 'credit-alert.v1' for this schema."
    },
    "event_id": {
      "type": "string",
      "description": "Globally unique id (UUID) for this alert event.",
      "minLength": 1
    },
    "account_id": {
      "type": "string",
      "description": "Account identifier (UUID).",
      "minLength": 1
    },
    "threshold": {
      "type": "number",
      "description": "The threshold that was crossed.",
      "exclusiveMinimum": 0
    },
    "balance": {
      "type": "number",
      "description": "Account balance at the time the threshold was crossed.",
      "minimum": 0
    },
    "channels": {
      "type": "object",
      "description": "Which delivery channels were enabled when this alert fired.",
      "properties": {
        "in_app": { "type": "boolean" },
        "email": { "type": "boolean" },
        "webhook": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 timestamp of when the alert fired."
    }
  },
  "additionalProperties": false
}
